{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist"
  },
  "include": ["*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "integration-test.ts", "test-embeddings.ts"]
}
