{
  "name": "@konuamah/context-bank",
  "version": "0.1.0",
  "description": "Persistent context bank for OpenCode with semantic search — no external dependencies.",
  "type": "module",
  "author": "Kelvin Owusu Nuamah <kelvinnuamah123@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konuamah/context-bank.git"
  },
  "bugs": {
    "url": "https://github.com/konuamah/context-bank/issues"
  },
  "homepage": "https://github.com/konuamah/context-bank#readme",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "context",
    "memory",
    "semantic-search",
    "ai",
    "embeddings",
    "rag",
    "retrieval"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "setup": "npx tsx setup.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
