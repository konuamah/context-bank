{
  "name": "opencode-context-bank",
  "version": "0.1.0",
  "description": "A persistent context bank plugin for OpenCode — retrieves, stores, and compresses coding session memory.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "setup": "npx tsx setup.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
